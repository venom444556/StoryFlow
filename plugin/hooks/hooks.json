{
  "description": "StoryFlow plugin hooks. Hooks are silent signal producers. All PM work is handled by the StoryFlow daemon (plugin/daemon/storyflowd.mjs), launched on SessionStart. No hook injects prompts into the Claude stream. No hook nags. The daemon handles reconciliation, session saves, and autonomous PM work via the storyflow CLI.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/daemon/start.sh && bash ${CLAUDE_PLUGIN_ROOT}/daemon/signal.sh session-start && bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-boot.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/pre-commit-gate.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/post-commit-sync.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/daemon/signal.sh file-edit",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/daemon/signal.sh turn-stop",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
